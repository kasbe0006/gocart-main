# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL = '$'

# Database
DATABASE_URL = "postgresql://postgres:postgres@localhost:5432/velmora"
DIRECT_URL = "postgresql://postgres:postgres@localhost:5432/velmora"

# Auth
AUTH_JWT_SECRET = "replace-with-a-long-random-secret"
AUTH_RESET_TOKEN_TTL_MINUTES = 15

# Seed defaults (optional)
SEED_ADMIN_EMAIL = "admin@velmora.com"
SEED_ADMIN_PASSWORD = "Admin@123"
SEED_MANAGER_EMAIL = "manager@velmora.com"
SEED_MANAGER_PASSWORD = "Manager@123"
SEED_STORE_OWNER_EMAIL = "owner@velmora.com"
SEED_STORE_OWNER_PASSWORD = "Owner@123"
